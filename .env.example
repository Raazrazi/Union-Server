# Server Port
PORT=5000

# JWT Secret Key
JWT_SECRET=union_vault_secret_key_12345

# MongoDB Connection String (leave blank to fallback to local JSON DB)
MONGODB_URI=mongodb://127.0.0.1:27017/unionvault

# Cloudinary Credentials (leave blank to fallback to local static file storage)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
